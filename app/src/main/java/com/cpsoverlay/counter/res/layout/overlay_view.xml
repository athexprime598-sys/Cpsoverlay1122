<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC0A0A0A"
    android:padding="6dp"
    android:gravity="center">

    <LinearLayout
        android:id="@+id/dragHandle"
        android:layout_width="match_parent"
        android:layout_height="18dp"
        android:background="#1FAA0D"
        android:gravity="center"
        android:layout_marginBottom="4dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⋮⋮ drag · hold to hide (F8)"
            android:textColor="#000000"
            android:textSize="9sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/cpsReadout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LMB 0  |  RMB 0 CPS"
        android:textColor="#39FF14"
        android:textStyle="bold"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/fpsReadout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Overlay FPS: --"
        android:textColor="#FFFFFF"
        android:textSize="9sp"
        android:layout_marginBottom="2dp" />

    <com.cpsoverlay.counter.ClickHistoryView
        android:id="@+id/historyGraph"
        android:layout_width="120dp"
        android:layout_height="26dp"
        android:layout_marginBottom="4dp" />

    <com.cpsoverlay.counter.KeyHudView
        android:id="@+id/keyHud"
        android:layout_width="90dp"
        android:layout_height="60dp"
        android:layout_marginBottom="6dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/lmbButton"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginEnd="6dp"
            android:text="LMB"
            android:textSize="10sp"
            android:backgroundTint="#39FF14"
            android:textColor="#000000" />

        <Button
            android:id="@+id/rmbButton"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="RMB"
            android:textSize="10sp"
            android:backgroundTint="#FF4444"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</LinearLayout>
